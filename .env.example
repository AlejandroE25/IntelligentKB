# Copy this file to .env and fill in your Anthropic API key.
# Never commit your actual .env file to version control.
ANTHROPIC_API_KEY=your-api-key

# Optional: Brave Search API key for "Users with Similar Issues" web results.
# When set, a "Users with Similar Issues / Potential Solutions" box appears in
# the right panel whenever fewer than 1 KB article receives a "High" relevancy
# badge.  Obtain a free key at https://brave.com/search/api/
BRAVE_API_KEY=your-brave-api-key

# Optional runtime controls for Claude cost/behavior
TOP_K_ARTICLES=3
MAX_TOKENS=1024
MAX_AGENT_TURNS=3
MAX_ARTICLE_CHARS_IN_PROMPT=2500
MAX_CONTACTS_CHARS_IN_PROMPT=1500
ANTHROPIC_MAX_RETRIES=1

# Optional feature flags for retrieval and prompting behavior.  Set to "true" to enable.
FEATURE_HYBRID_RETRIEVAL=true # TF-IDF + semantic RRF fusion
FEATURE_QUERY_NORMALIZATION=true # synonym expansion; typo fallback when lexical confidence is low
FEATURE_ADAPTIVE_TOPK=true # score-gap based top-k selection
FEATURE_SEARCH_CACHE=true # LRU cache for retrieval results

# Azure Blob Storage — for article and data persistence across redeploys.
# On Azure Web App, leave CONNECTION_STRING blank and use Managed Identity instead.
# To use Managed Identity: assign "Storage Blob Data Contributor" role to the app identity.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ARTICLES_CONTAINER=articles
AZURE_STORAGE_DATA_CONTAINER=appdata
AZURE_STORAGE_CONNECTION_STRING=  # local dev only; leave blank on Azure

# Set to 1 to skip Claude quality assessment at startup (useful for fast local dev restarts).
# The quality cache (quality_cache.json) is reused on subsequent restarts automatically.
SKIP_QUALITY_ASSESSMENT=

# Model used for article quality assessment (defaults to claude-haiku-4-5 for cost efficiency).
# Override to claude-sonnet-4-6 for higher quality assessments.
QUALITY_ASSESSMENT_MODEL=claude-haiku-4-5-20251001

# SECURITY NOTE: /admin/quality is currently unauthenticated.
# Add IP allowlist, basic auth, or Azure AD authentication before exposing externally.